# =============================================================
# Jira Connection Settings
# =============================================================

JIRA_URL=https://tkts.sys.comcast.net

# =============================================================
# Authentication Mode: "pat", "basic", or "cloud"
# =============================================================
JIRA_AUTH_MODE=pat
JIRA_PAT=your-personal-access-token-here

# --- Other auth options (uncomment if needed) ---
# JIRA_USERNAME=your.username
# JIRA_PASSWORD=your-password
# JIRA_EMAIL=your.email@company.com
# JIRA_API_TOKEN=your-cloud-api-token

# =============================================================
# Project Settings
# =============================================================
FEATURE_PROJECT_KEY=BXT
PROJECT_PREFIX=BXT

# =============================================================
# Status Definitions (per level)
# Each level has its own Jira workflow with different status names.
# Comma-separated, case-sensitive — must match Jira exactly.
# =============================================================

# --- Feature statuses ---
FEATURE_RESOLVED_STATUSES=In Production,Cancelled
FEATURE_IN_PROGRESS_STATUSES=Solutioning,Solution Approved,Grooming/Refinement,Ready for Dev,In Progress,Certified,In Production toggled off

# --- Epic statuses ---
EPIC_RESOLVED_STATUSES=In production,Cancelled
EPIC_IN_PROGRESS_STATUSES=Evaluation,Architecture Review,Design,Ready for Dev,Developing,E2E testing,Certified,In production toggled off

# --- Story statuses ---
STORY_RESOLVED_STATUSES=Accepted,Cancelled
STORY_IN_PROGRESS_STATUSES=Defined,In-Progress,Code Review,Ready for Testing,Testing,Ready for Acceptance
